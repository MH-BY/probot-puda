NATS_SERVERS=nats://100.109.131.12:4222,nats://100.109.131.12:4223,nats://100.109.131.12:4224
MACHINE_ID=smu-keysight-probot

# Keysight SMU: set an explicit VISA address (recommended). If blank, the driver
# falls back to the KEYSIGHT_DEVICE_NO-th VISA resource found.
KEYSIGHT_ADDRESS=
KEYSIGHT_DEVICE_NO=0

# Pico G2V light controller (Ethernet) - co-located with the SMU because several
# measurements drive the light inline during the SMU acquisition.
PICO_IP=169.254.182.113
PICO_ID=00000000e11c66da

# Writable directories for measurement parameters and output data.
# PARAM_DIR must be writable (HT_PotDep / the GUI rewrite parameter CSVs).
PARAM_DIR=./Parameters
DATA_DIR=./Data/Keysight
